LOG_LEVEL=INFO
LOG_FORMAT=console
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql+asyncpg://habagou:habagou@localhost:5432/habagou
SESSION_SECRET_KEY=change-me
SESSION_COOKIE_SECURE=false
OIDC_PROVIDER=keycloak
OIDC_SCOPES=openid profile email
# devenv Keycloak defaults to :12345; Compose Keycloak publishes :18080
OIDC_ISSUER=http://127.0.0.1:12345/realms/habagou
OIDC_CLIENT_ID=habagou
OIDC_CLIENT_SECRET=habagou-dev-secret
OTEL_EXPORTER_OTLP_ENDPOINT=
# Optional API, database, and AI tracing. Empty means Logfire export is disabled.
LOGFIRE_TOKEN=
# Agent pack generation (OpenAI-compatible models via OpenRouter). Unset key => generation
# disabled and POST /api/v1/generation/draft returns 503.
OPENROUTER_API_KEY=
GENERATION_MODEL=openai/gpt-5.6-terra
GENERATION_RATE_LIMIT_PER_HOUR=10
PRACTICE_MODEL=openai/gpt-5.6-terra
PRACTICE_RATE_LIMIT_PER_HOUR=60
