{
  "name": "habagou",
  "version": "0.1.0",
  "description": "Learn to write Chinese characters by tracing them, stroke by stroke.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsr generate && tsc -b && vite build",
    "preview": "vite preview",
    "fmt": "biome check . --linter-enabled=false --organize-imports-enabled=false",
    "fmt-fix": "biome format --write .",
    "lint": "biome lint .",
    "lint-fix": "biome lint . --write",
    "typecheck": "tsr generate && tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/hanken-grotesk": "^5.2.6",
    "@fontsource/noto-sans-sc": "^5.2.6",
    "@tanstack/react-query": "^5.75",
    "@tanstack/react-router": "^1.120",
    "hanzi-writer": "^3.7.2",
    "react": "^19.0",
    "react-dom": "^19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@playwright/test": "^1.49",
    "@tanstack/router-cli": "^1.167",
    "@tanstack/router-plugin": "^1.120",
    "@testing-library/jest-dom": "^6.6",
    "@testing-library/react": "^16.0",
    "@types/react": "^19.0",
    "@types/react-dom": "^19.0",
    "@vitejs/plugin-react": "^4.3",
    "autoprefixer": "^10.4",
    "jsdom": "^26.0",
    "msw": "^2.7",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4",
    "tailwindcss": "^3.4",
    "typescript": "^5.7",
    "vite": "^6.3",
    "vitest": "^3.0"
  }
}
