  "info": {
    "description": "Learn to write Chinese characters by tracing them, stroke by stroke.",
    "title": "habagou",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/auth/session": {
      "get": {
        "operationId": "get_auth_session_api_v1_auth_session_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionDTO"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Auth Session",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/characters/{hanzi}/strokes": {
      "get": {
        "operationId": "get_character_strokes_api_v1_characters__hanzi__strokes_get",
        "parameters": [
          {
            "in": "path",
            "name": "hanzi",
            "required": true,
            "schema": {
              "title": "Hanzi",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Get Character Strokes Api V1 Characters  Hanzi  Strokes Get",
                  "type": "object"
                }
              }
            },
            "description": "Hanzi Writer stroke JSON"
          },
          "404": {
            "description": "Character stroke data not found"
          },
          "422": {
            "description": "Path parameter must be exactly one grapheme"
          }
        },
        "summary": "Get Character Strokes",
        "tags": [
          "characters"
        ]
      }
    },
    "/api/v1/generation/draft": {
      "post": {
        "description": "Draft (or refine) a corpus-grounded pack for the caller's topic.",
        "operationId": "generate_draft_api_v1_generation_draft_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerationDraftRequestDTO"
              }
            }
          },
          "required": true
        },
